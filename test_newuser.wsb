<Configuration>
  <!-- Тест GoodNightBot «как новый юзер»: чистая Windows без Python.
       Двойной клик по этому файлу (после однократного включения Windows Sandbox).
       См. C:\Users\iPipen\.claude\sandbox\README.md -->
  <Networking>Enable</Networking>
  <MemoryInMB>4096</MemoryInMB>
  <MappedFolders>
    <MappedFolder>
      <HostFolder>D:\FOR_MYSELF\TBH_BOT\installer</HostFolder>
      <SandboxFolder>C:\Users\WDAGUtilityAccount\Desktop\GoodNightBot-installer</SandboxFolder>
      <ReadOnly>true</ReadOnly>
    </MappedFolder>
  </MappedFolders>
  <LogonCommand>
    <Command>explorer.exe C:\Users\WDAGUtilityAccount\Desktop\GoodNightBot-installer</Command>
  </LogonCommand>
</Configuration>
